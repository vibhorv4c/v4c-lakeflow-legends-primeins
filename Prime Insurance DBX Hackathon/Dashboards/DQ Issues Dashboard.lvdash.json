{
  "datasets": [
    {
      "name": "5c24ba72",
      "displayName": "Detailed Compliance Log",
      "queryLines": [
        "SELECT \r\n",
        "  initcap(table_name) AS `Entity`,\r\n",
        "  column_name AS `Column`,\r\n",
        "  issue_description AS `Issue Description`,\r\n",
        "  severity AS `Severity`,\r\n",
        "  affected_records AS `Affected Rows`,\r\n",
        "  CONCAT(ROUND(affected_ratio * 100, 2), '%') AS `Impact Rate`,\r\n",
        "  suggested_fix AS `Suggested Action`\r\n",
        "FROM primeins.silver.dq_issues\r\n",
        "ORDER BY \r\n",
        "  CASE WHEN severity LIKE 'Error%' THEN 1 ELSE 2 END, \r\n",
        "  affected_records DESC;"
      ]
    },
    {
      "name": "ac2cbb9e",
      "displayName": "Severity by Entity",
      "queryLines": [
        "SELECT \r\n",
        "  initcap(table_name) AS `Entity`, \r\n",
        "  severity AS `Severity`, \r\n",
        "  SUM(affected_records) AS `Total Records`\r\n",
        "FROM primeins.silver.dq_issues\r\n",
        "GROUP BY table_name, severity\r\n",
        "ORDER BY `Total Records` DESC;"
      ]
    },
    {
      "name": "0fe4a9bd",
      "displayName": "High-Level KPIs",
      "queryLines": [
        "SELECT \r\n",
        "  SUM(CASE WHEN severity LIKE 'Error%' THEN affected_records ELSE 0 END) AS `Total Quarantined (Errors)`,\r\n",
        "  SUM(CASE WHEN severity LIKE 'Warning%' THEN affected_records ELSE 0 END) AS `Total Warnings (Passed)`\r\n",
        "FROM primeins.silver.dq_issues;"
      ]
    }
  ],
